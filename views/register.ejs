<%- include('partials/header') %>
<div class="glass-panel" style="max-width: 500px; margin: 0 auto;">
    <h2 class="text-center mb-4">Join Nebula</h2>
    <form method="POST" action="/register">
        <div class="form-group">
            <label class="form-label" for="username">Username</label>
            <input class="form-control" type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input class="form-control" type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
            <label class="form-label" for="password">Password</label>
            <input class="form-control" type="password" id="password" name="password" required>
        </div>
        <div class="form-group mt-4">
            <button class="btn" style="width: 100%;" type="submit">Sign Up</button>
        </div>
    </form>
    <div class="text-center mt-4 pt-4" style="border-top: 1px solid var(--border-light);">
        <p style="color: var(--text-muted);">Already Have An Account? <a href="/login">Sign In</a></p>
    </div>
</div>
<%- include('partials/footer') %>
