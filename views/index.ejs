<%- include('partials/header') %>
    <div style="text-align: center; margin-bottom: 4rem;">
        <h1 style="font-size: 3.5rem; font-weight: 800; background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 1rem; letter-spacing: -1px;">Explore the Nebula</h1>
        <p style="color: var(--text-muted); font-size: 1.25rem; font-weight: 500;">Discover thoughts, stories, and ideas in our vibrant community.</p>
    </div>

    <% if (posts && posts.length > 0) { %>
        <% posts.forEach(function(post) { %>
            <article class="post-card">
                <h2 class="post-title"><a href="/post/<%= post.id %>"><%= post.title %></a></h2>
                <div class="post-meta">
                    <span>By <%= post.author ? post.author.username : 'Unknown' %></span> &bull; 
                    <span><%= new Date(post.date_posted).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                </div>
                <p class="post-content"><%= (post.content && typeof post.content === 'string') ? post.content.substring(0, 200) : '' %>...</p>
                <div class="mt-4">
                    <a href="/post/<%= post.id %>" class="btn btn-outline" style="font-size: 0.9rem; padding: 0.5rem 1.2rem;">Read More</a>
                </div>
            </article>
        <% }); %>
    <% } else { %>
        <div class="glass-panel text-center" style="padding: 4rem 2rem;">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">No posts yet!</h3>
            <p style="color: var(--text-muted);">Be the first to create one.</p>
            <a href="/post/new" class="btn mt-4">Create Post</a>
        </div>
    <% } %>
<%- include('partials/footer') %>
